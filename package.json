        "ganache-core": "^2.13.2",
        "glob": "^7.1.6",
        "memdown": "^5.1.0",
        "mocha": "^8.2.1",
        "node-html-parser": "^4.1.5",
        "solc-vm": "https://gitpkg.now.sh/EthereansOS/Multiverse-Interface/solc-vm?master",
